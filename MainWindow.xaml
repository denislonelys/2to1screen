<Window x:Class="TwoTo1Screen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TwoTo1Screen.Views"
        Title="2to1screen"
        Width="980" Height="650"
        MinWidth="980" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Border x:Name="RootBorder" CornerRadius="20"
            Background="{DynamicResource WindowBackdrop}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid>
            <!-- Animated theme backdrop (behind everything) -->
            <Grid x:Name="BackdropHost" Visibility="Collapsed" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ===================== Title bar ===================== -->
                <Grid x:Name="TitleBar" Grid.Row="0" Height="52" Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Border Width="30" Height="30" CornerRadius="9"
                                Background="{DynamicResource AccentGradient}" BorderBrush="#66FFFFFF" BorderThickness="1">
                            <TextBlock Text="2›1" Foreground="{DynamicResource AccentTextBrush}" FontWeight="Bold" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="2to1screen" Foreground="{DynamicResource TextPrimary}"
                                   FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="11,0,0,0" />
                        <Border Background="#22FFFFFF" CornerRadius="7" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Windows 11" Style="{StaticResource Caption}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button x:Name="BtnMin" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="BtnMin_Click" />
                        <Button x:Name="BtnClose" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="BtnClose_Click" />
                    </StackPanel>
                </Grid>

                <!-- ===================== Body ===================== -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar strip -->
                    <Border Grid.Column="0" CornerRadius="16" Margin="12,0,6,12"
                            Background="{DynamicResource SidebarFill}"
                            BorderBrush="{DynamicResource GlassStrokeSoft}" BorderThickness="1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                                <RadioButton x:Name="NavApp" Style="{StaticResource NavItem}" GroupName="Nav"
                                             Tag="🖥️" Content="Приложение" IsChecked="True"
                                             Checked="Nav_Checked" />
                                <RadioButton x:Name="NavSettings" Style="{StaticResource NavItem}" GroupName="Nav"
                                             Tag="⚙️" Content="Настройки" Checked="Nav_Checked" />
                                <RadioButton x:Name="NavThemes" Style="{StaticResource NavItem}" GroupName="Nav"
                                             Tag="🎨" Content="Магазин тем" Checked="Nav_Checked" />
                                <RadioButton x:Name="NavDev" Style="{StaticResource NavItem}" GroupName="Nav"
                                             Tag="👤" Content="Разработчик" Checked="Nav_Checked" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,14" HorizontalAlignment="Center">
                                <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#FF8893A2" HorizontalAlignment="Center" />
                                <TextBlock x:Name="StatusText" Text="Выкл." Style="{StaticResource Caption}"
                                           HorizontalAlignment="Center" Margin="0,5,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Content -->
                    <Grid Grid.Column="1" Margin="6,0,12,12">
                        <views:AppView x:Name="PageApp" />
                        <views:SettingsView x:Name="PageSettings" Visibility="Collapsed" />
                        <views:ThemeStoreView x:Name="PageThemes" Visibility="Collapsed" />
                        <views:DeveloperView x:Name="PageDev" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
