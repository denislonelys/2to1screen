<UserControl x:Class="TwoTo1Screen.Views.DeveloperView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8,4,2,0">
        <Border Style="{StaticResource Card}" Padding="40,34" HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="380">
            <StackPanel HorizontalAlignment="Center">
                <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center"
                        Background="{StaticResource AccentGradient}" BorderBrush="#66FFFFFF" BorderThickness="1">
                    <TextBlock Text="👨‍💻" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextOptions.TextFormattingMode="Ideal" />
                </Border>

                <TextBlock Text="Разработчик" Style="{StaticResource H1}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                <TextBlock Text="dirroladd" Style="{StaticResource Body}" HorizontalAlignment="Center" Margin="0,4,0,0" />

                <Button x:Name="BtnVk" Style="{StaticResource AccentButton}" Content="vk.ru/dirroladd"
                        HorizontalAlignment="Center" Margin="0,22,0,0" Padding="28,12" Click="BtnVk_Click" />

                <TextBlock Text="Нажмите, чтобы открыть страницу ВКонтакте" Style="{StaticResource Caption}"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
