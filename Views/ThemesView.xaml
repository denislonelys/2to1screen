<UserControl x:Class="TwoTo1Screen.Views.ThemesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TwoTo1Screen.Views">
    <Grid Margin="8,4,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="2,0,2,12">
            <TextBlock Text="Темы" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0"
                       Text="Liquid Glass, прозрачность, магазин из 500+ тем и свои темы." />
        </StackPanel>

        <!-- ===== Liquid Glass block (отдельный блок над магазином) ===== -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <Grid views:BindHelper.Action="toggle_glass">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Liquid Glass" Style="{StaticResource H2}" />
                        <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0"
                                   Text="Прозрачная стеклянная тема — сквозь окно видно обои. По умолчанию выключено." />
                    </StackPanel>
                    <CheckBox x:Name="SwGlass" Grid.Column="1" Style="{StaticResource GlassSwitch}"
                              VerticalAlignment="Center" Click="SwGlass_Click" />
                </Grid>

                <Border Height="1" Background="{DynamicResource GlassStrokeSoft}" Margin="0,14" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Прозрачность" Style="{StaticResource H2}" />
                    <TextBlock x:Name="TransVal" Grid.Column="1" Style="{StaticResource H2}" />
                </Grid>
                <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0"
                           Text="0 — без прозрачности (видны только бары), 100 — окно почти полностью прозрачное." />
                <Slider x:Name="TransSlider" Style="{StaticResource GlassSlider}" Minimum="0" Maximum="100"
                        SmallChange="1" LargeChange="10" Margin="0,8,0,0" ValueChanged="TransSlider_ValueChanged" />
                <TextBlock x:Name="GlassOffNote" Style="{StaticResource Caption}" Foreground="{DynamicResource TextMuted}"
                           Margin="0,4,0,0" Text="Прозрачность применяется при включённом Liquid Glass." Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- ===== Свои темы ===== -->
        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Свои темы" Style="{StaticResource H2}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Лёгкая: фото + цвет" Style="{StaticResource GlassButton}" Click="NewEasy_Click" />
                    <Button Content="Своя: вставить код" Style="{StaticResource GlassButton}" Margin="8,0,0,0" Click="NewAdvanced_Click" />
                </StackPanel>
            </Grid>
            <ItemsControl x:Name="CustomList" Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <TextBlock x:Name="NoCustom" Style="{StaticResource Caption}" Text="Пока нет своих тем."
                       Margin="2,2,0,0" />
        </StackPanel>

        <!-- ===== Магазин тем ===== -->
        <Grid Grid.Row="3" Margin="0,18,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StoreTitle" Grid.Column="0" Text="Магазин тем" Style="{StaticResource H2}" VerticalAlignment="Center" />
            <Border Grid.Column="1" CornerRadius="10" Background="{DynamicResource GlassFill}"
                    BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="8,2">
                <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                         VerticalContentAlignment="Center" Padding="2,4" TextChanged="SearchBox_TextChanged" />
            </Border>
        </Grid>

        <ListBox x:Name="ThemeList" Grid.Row="4" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 SelectionChanged="ThemeList_SelectionChanged" SelectionMode="Single">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0,0,8,8" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="b" CornerRadius="12" Background="{DynamicResource GlassFill}"
                                        BorderBrush="{DynamicResource GlassStrokeSoft}" BorderThickness="1" Padding="10">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource GlassFillHover}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentSolid}" />
                                        <Setter TargetName="b" Property="BorderThickness" Value="2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- mini preview -->
                        <Border Grid.Column="0" Width="104" Height="60" CornerRadius="8"
                                Background="{Binding BgBrush}" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{Binding SurfaceBrush}" CornerRadius="8,0,0,8" />
                                <StackPanel Grid.Column="1" Margin="8,9,8,0">
                                    <Border Height="7" Width="44" CornerRadius="4" HorizontalAlignment="Left"
                                            Background="{Binding AccentBrush}" />
                                    <Border Height="5" Width="52" CornerRadius="3" HorizontalAlignment="Left"
                                            Background="{Binding TextBrush}" Margin="0,7,0,0" Opacity="0.85" />
                                    <Border Height="5" Width="38" CornerRadius="3" HorizontalAlignment="Left"
                                            Background="{Binding MutedBrush}" Margin="0,5,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="SemiBold" FontSize="13.5" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding AuthorLine}" Style="{StaticResource Caption}" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
