<UserControl x:Class="TwoTo1Screen.Views.ThemesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TwoTo1Screen.Views">
    <UserControl.Resources>
        <!-- square store tile -->
        <Style x:Key="ThemeTile" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource GlassFill}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassStrokeSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GlassFillHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource GlassStroke}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentSolid}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- one theme card -->
        <DataTemplate x:Key="TileTemplate">
            <Border Style="{StaticResource ThemeTile}" MouseLeftButtonUp="Tile_Click">
                <StackPanel>
                    <!-- mini app preview -->
                    <Border Height="104" CornerRadius="9" Background="{Binding BgBrush}" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{Binding SurfaceBrush}" CornerRadius="9,0,0,9" />
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="11" Height="11" Fill="{Binding AccentBrush}" />
                                <Ellipse Width="11" Height="11" Fill="{Binding MutedBrush}" Margin="0,6,0,0" Opacity="0.7" />
                                <Ellipse Width="11" Height="11" Fill="{Binding MutedBrush}" Margin="0,6,0,0" Opacity="0.7" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="11,14,12,0">
                                <Border Height="9" Width="58" CornerRadius="5" HorizontalAlignment="Left"
                                        Background="{Binding AccentBrush}" />
                                <Border Height="7" Width="92" CornerRadius="4" HorizontalAlignment="Left"
                                        Background="{Binding TextBrush}" Margin="0,9,0,0" Opacity="0.9" />
                                <Border Height="7" Width="74" CornerRadius="4" HorizontalAlignment="Left"
                                        Background="{Binding MutedBrush}" Margin="0,6,0,0" />
                                <Border Height="7" Width="84" CornerRadius="4" HorizontalAlignment="Left"
                                        Background="{Binding MutedBrush}" Margin="0,6,0,0" Opacity="0.8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="13" Margin="2,10,0,0" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding AuthorLine}" Style="{StaticResource Caption}" Margin="2,2,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- a row of up to N tiles (the virtualized unit) -->
        <DataTemplate x:Key="RowTemplate">
            <ItemsControl ItemsSource="{Binding}" ItemTemplate="{StaticResource TileTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8,4,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="2,0,2,12">
            <TextBlock Text="Темы" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0"
                       Text="Магазин из 500+ тем и свои темы. Liquid Glass — в отдельной вкладке." />
        </StackPanel>

        <!-- ===== Свои темы ===== -->
        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Свои темы" Style="{StaticResource H2}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Лёгкая: фото + цвет" Style="{StaticResource GlassButton}" Click="NewEasy_Click" />
                    <Button Content="Своя: вставить код" Style="{StaticResource GlassButton}" Margin="8,0,0,0" Click="NewAdvanced_Click" />
                </StackPanel>
            </Grid>
            <ItemsControl x:Name="CustomList" Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <TextBlock x:Name="NoCustom" Style="{StaticResource Caption}" Text="Пока нет своих тем."
                       Margin="2,2,0,0" />
        </StackPanel>

        <!-- ===== Магазин тем ===== -->
        <Grid Grid.Row="2" Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StoreTitle" Grid.Column="0" Text="Магазин тем" Style="{StaticResource H2}" VerticalAlignment="Center" />
            <Border Grid.Column="1" CornerRadius="10" Background="{DynamicResource GlassFill}"
                    BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="10,2">
                <Grid>
                    <TextBlock x:Name="SearchHint" Text="Поиск темы…" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0" />
                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                             VerticalContentAlignment="Center" Padding="2,5" TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>
        </Grid>

        <ListBox x:Name="ThemeList" Grid.Row="3" Background="Transparent" BorderThickness="0"
                 Focusable="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 ItemTemplate="{StaticResource RowTemplate}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Focusable" Value="False" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</UserControl>
