<UserControl x:Class="TwoTo1Screen.Views.AppView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8,4,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="2,0,2,14">
            <TextBlock Text="Приложение" Style="{StaticResource H1}" />
            <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0"
                       Text="Качественные скриншоты только одного монитора. Win + PrintScreen больше не будет склеивать оба экрана и резать качество." />
        </StackPanel>

        <!-- Body -->
        <StackPanel Grid.Row="1">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖥️" FontSize="20" VerticalAlignment="Center"
                                   TextOptions.TextFormattingMode="Ideal" />
                        <TextBlock Text="Как это работает" Style="{StaticResource H2}" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                               Text="Нажмите «Запустить» — приложение перехватит клавишу Print Screen и сделает снимок только выбранного в настройках монитора в полном качестве. Снимок копируется в буфер обмена и сохраняется в файл." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <StackPanel>
                    <!-- Auto start -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Запускать автоматически" Style="{StaticResource H2}" />
                            <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0"
                                       Text="Старт в фоне при входе в Windows (требуются права администратора)." />
                        </StackPanel>
                        <CheckBox x:Name="SwAutoStart" Grid.Column="1" Style="{StaticResource GlassSwitch}"
                                  VerticalAlignment="Center" Click="SwAutoStart_Click" />
                    </Grid>

                    <Border Height="1" Background="#22FFFFFF" Margin="0,16" />

                    <!-- Disable liquid glass -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Выключить Liquid Glass" Style="{StaticResource H2}" />
                            <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0"
                                       Text="Полностью отключает прозрачную стеклянную тему. По умолчанию выключено." />
                        </StackPanel>
                        <CheckBox x:Name="SwGlass" Grid.Column="1" Style="{StaticResource GlassSwitch}"
                                  VerticalAlignment="Center" Click="SwGlass_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="2,16,2,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                <Ellipse x:Name="RunDot" Width="10" Height="10" Fill="#FF8893A2" VerticalAlignment="Center" />
                <TextBlock x:Name="RunLabel" Text="Сервис остановлен" Style="{StaticResource Body}"
                           Margin="9,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <Button x:Name="BtnLaunch" Grid.Column="1" Style="{StaticResource AccentButton}"
                    Content="Запустить" MinWidth="170" Click="BtnLaunch_Click" />
        </Grid>
    </Grid>
</UserControl>
