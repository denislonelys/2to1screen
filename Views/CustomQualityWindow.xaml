<Window x:Class="TwoTo1Screen.Views.CustomQualityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Своё качество"
        Width="460" Height="430"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border x:Name="RootBorder" CornerRadius="18"
            Background="{DynamicResource WindowBackdrop}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="Настроить качество самому" Style="{StaticResource H1}" FontSize="20" />
                    <TextBlock x:Name="MaxInfo" Style="{StaticResource Caption}" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Масштаб разрешения" Style="{StaticResource H2}" />
                    <TextBlock x:Name="ScaleValue" Grid.Column="1" Style="{StaticResource H2}" Foreground="{DynamicResource TextPrimary}" />
                </Grid>
                <Slider x:Name="ScaleSlider" Style="{StaticResource GlassSlider}" Minimum="10" Maximum="100"
                        SmallChange="1" LargeChange="10" TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,8,0,0" ValueChanged="ScaleSlider_ValueChanged" />
                <TextBlock x:Name="ResultRes" Style="{StaticResource Caption}" Margin="0,4,0,0" />

                <TextBlock Text="Формат файла" Style="{StaticResource H2}" Margin="0,20,0,8" />
                <WrapPanel>
                    <RadioButton x:Name="FmtPng" Style="{StaticResource SelectChip}" GroupName="Fmt" Content="PNG (без потерь)" Checked="Fmt_Checked" />
                    <RadioButton x:Name="FmtJpeg" Style="{StaticResource SelectChip}" GroupName="Fmt" Content="JPEG (меньше размер)" Checked="Fmt_Checked" />
                </WrapPanel>

                <Grid x:Name="JpegPanel" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Качество JPEG" Style="{StaticResource H2}" />
                            <TextBlock x:Name="JpegValue" Grid.Column="1" Style="{StaticResource H2}" />
                        </Grid>
                        <Slider x:Name="JpegSlider" Style="{StaticResource GlassSlider}" Minimum="40" Maximum="100"
                                SmallChange="1" LargeChange="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                Margin="0,8,0,0" ValueChanged="JpegSlider_ValueChanged" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Style="{StaticResource GlassButton}" MinWidth="100" Click="Cancel_Click" />
                <Button Content="Сохранить" Style="{StaticResource AccentButton}" MinWidth="120" Margin="10,0,0,0"
                        Padding="20,9" FontSize="13" Click="Ok_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
