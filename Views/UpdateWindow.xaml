<Window x:Class="TwoTo1Screen.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление 2to1screen"
        Width="440" Height="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border CornerRadius="20" Background="{DynamicResource WindowFill}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid Margin="30,26,30,26">
            <StackPanel VerticalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="20" HorizontalAlignment="Center"
                        Background="{DynamicResource AccentGradient}" BorderBrush="#66FFFFFF" BorderThickness="1">
                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                               Foreground="{DynamicResource AccentForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="TitleText" Text="Доступно обновление" Style="{StaticResource H1}" FontSize="21"
                           HorizontalAlignment="Center" Margin="0,16,0,0" />
                <TextBlock x:Name="SubText" Style="{StaticResource Body}" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,8,0,0"
                           Text="Обновление обязательно. Сейчас программа обновится и перезапустится." />

                <ProgressBar x:Name="Bar" Height="8" Minimum="0" Maximum="100" Value="0" Margin="0,20,0,0"
                             Foreground="{DynamicResource AccentSolid}" Background="{DynamicResource GlassFill}"
                             BorderThickness="0" />
                <TextBlock x:Name="PercentText" Style="{StaticResource Caption}" HorizontalAlignment="Center" Margin="0,8,0,0" Text="" />

                <Button x:Name="BtnRetry" Style="{StaticResource AccentButton}" Content="Повторить"
                        HorizontalAlignment="Center" Margin="0,16,0,0" Visibility="Collapsed" Click="Retry_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
