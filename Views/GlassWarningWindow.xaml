<Window x:Class="TwoTo1Screen.Views.GlassWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liquid Glass"
        Width="470" Height="262"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border x:Name="RootBorder" CornerRadius="18"
            Background="{DynamicResource WindowBackdrop}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid Margin="26,22,26,22" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="24" VerticalAlignment="Center"
                           TextOptions.TextFormattingMode="Ideal" />
                <TextBlock Text="Сейчас включён Liquid Glass" Style="{StaticResource H1}" FontSize="20"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>

            <TextBlock Grid.Row="1" Style="{StaticResource Body}" Margin="0,16,0,0" VerticalAlignment="Top"
                       Text="Темы из магазина работают вместо Liquid Glass. Чтобы выбрать другую тему, нужно сначала выключить режим Liquid Glass. Выключить его сейчас?" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Отмена" Style="{StaticResource GhostButton}" MinWidth="110" Click="Cancel_Click" />
                <Button Content="Выключить Liquid Glass" Style="{StaticResource DangerButton}"
                        MinWidth="210" Margin="12,0,0,0" Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
