<Window x:Class="TwoTo1Screen.Views.CustomThemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Своя тема"
        Width="480" Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border CornerRadius="18" Background="{DynamicResource WindowFill}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_Drag">
                <TextBlock x:Name="TitleText" Text="Своя тема" Style="{StaticResource H1}" FontSize="20" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="Название" Style="{StaticResource H2}" Margin="0,0,0,6" />
                <Border CornerRadius="10" Background="{DynamicResource GlassFill}" BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="4">
                    <TextBox x:Name="NameBox" Background="Transparent" BorderThickness="0" Padding="8,7"
                             Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" />
                </Border>

                <!-- EASY -->
                <StackPanel x:Name="EasyPanel">
                    <TextBlock Text="Прямая ссылка на PNG (фон)" Style="{StaticResource H2}" Margin="0,16,0,6" />
                    <Border CornerRadius="10" Background="{DynamicResource GlassFill}" BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="4">
                        <TextBox x:Name="ImgBox" Background="Transparent" BorderThickness="0" Padding="8,7" FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" />
                    </Border>
                    <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0"
                               Text="Например: https://example.com/wallpaper.png" />

                    <TextBlock Text="Основной цвет (акцент)" Style="{StaticResource H2}" Margin="0,16,0,6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Swatch" Grid.Column="0" Width="36" Height="36" CornerRadius="9"
                                BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" />
                        <Border Grid.Column="1" CornerRadius="10" Background="{DynamicResource GlassFill}" Margin="10,0,0,0"
                                BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="4">
                            <TextBox x:Name="AccentBox" Background="Transparent" BorderThickness="0" Padding="8,7"
                                     FontFamily="Consolas" Foreground="{DynamicResource TextPrimary}"
                                     CaretBrush="{DynamicResource TextPrimary}" TextChanged="AccentBox_TextChanged" />
                        </Border>
                        <Button Grid.Column="2" Content="Выбрать" Style="{StaticResource GlassButton}" Margin="10,0,0,0" Click="PickColor_Click" />
                    </Grid>

                    <TextBlock Text="Стиль текста" Style="{StaticResource H2}" Margin="0,16,0,6" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ModeDark" Style="{StaticResource SelectChip}" GroupName="Mode" Content="Тёмный" IsChecked="True" />
                        <RadioButton x:Name="ModeLight" Style="{StaticResource SelectChip}" GroupName="Mode" Content="Светлый" />
                    </StackPanel>
                </StackPanel>

                <!-- ADVANCED -->
                <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed">
                    <TextBlock Text="Код темы (JSON)" Style="{StaticResource H2}" Margin="0,16,0,6" />
                    <Border CornerRadius="10" Background="{DynamicResource GlassFill}" BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Padding="4">
                        <TextBox x:Name="CodeBox" Background="Transparent" BorderThickness="0" Padding="8,7"
                                 FontFamily="Consolas" FontSize="12.5" Height="230" AcceptsReturn="True"
                                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}" />
                    </Border>
                    <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="Поля: mode (dark/light), bg, bg2, surface, accent, accent2, text, textMuted. Цвета в формате #RRGGBB." />
                </StackPanel>

                <TextBlock x:Name="ErrText" Style="{StaticResource Body}" Foreground="#FFE0A0A0"
                           Margin="0,12,0,0" TextWrapping="Wrap" Visibility="Collapsed" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource GlassButton}" MinWidth="100" Click="Cancel_Click" />
                <Button Content="Сохранить" Style="{StaticResource AccentButton}" MinWidth="120" Margin="10,0,0,0"
                        Padding="20,9" FontSize="13" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
