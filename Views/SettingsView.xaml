<UserControl x:Class="TwoTo1Screen.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:TwoTo1Screen.Views">
    <Grid Margin="8,4,2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,2,12">
            <TextBlock Text="Настройки" Style="{StaticResource H1}" />
            <TextBlock Text="Выберите монитор, качество снимка и поведение приложения." Style="{StaticResource Body}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>

                <!-- Монитор -->
                <Border Style="{StaticResource Card}" views:BindHelper.Action="switch_monitor" Cursor="Hand">
                    <StackPanel>
                        <TextBlock Text="Монитор" Style="{StaticResource H2}" />
                        <TextBlock Text="С какого экрана делать снимок." Style="{StaticResource Caption}" Margin="0,3,0,10" />
                        <StackPanel x:Name="MonitorList" />
                        <TextBlock x:Name="MonitorHotkey" Style="{StaticResource Caption}" Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextMuted}"
                                   Text="Клик колёсиком по этому блоку — назначить горячую клавишу переключения монитора." />
                    </StackPanel>
                </Border>

                <!-- Качество -->
                <TextBlock Text="Качество скриншота" Style="{StaticResource H2}" Margin="2,18,0,8" />
                <WrapPanel>
                    <RadioButton x:Name="ChipVeryHigh" Style="{StaticResource SelectChip}" GroupName="Qual" Tag="VeryHigh" Content="Очень высокое" Checked="Quality_Checked" />
                    <RadioButton x:Name="ChipHigh" Style="{StaticResource SelectChip}" GroupName="Qual" Tag="High" Content="Высокое" Checked="Quality_Checked" />
                    <RadioButton x:Name="ChipMedium" Style="{StaticResource SelectChip}" GroupName="Qual" Tag="Medium" Content="Среднее" Checked="Quality_Checked" />
                    <RadioButton x:Name="ChipLow" Style="{StaticResource SelectChip}" GroupName="Qual" Tag="Low" Content="Низкое" Checked="Quality_Checked" />
                    <RadioButton x:Name="ChipCustom" Style="{StaticResource SelectChip}" GroupName="Qual" Tag="Custom" Content="Настроить самому" Checked="Quality_Checked" />
                </WrapPanel>
                <TextBlock x:Name="CustomInfo" Style="{StaticResource Caption}" Margin="2,2,0,0" Visibility="Collapsed" />

                <!-- Дополнительно -->
                <TextBlock Text="Дополнительно" Style="{StaticResource H2}" Margin="2,20,0,8" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Копировать в буфер обмена" Style="{StaticResource H2}" />
                                <TextBlock Text="Снимок сразу можно вставить в любую программу." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwClipboard" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>

                        <Border Height="1" Background="#1EFFFFFF" Margin="0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Сохранять в файл" Style="{StaticResource H2}" />
                                <TextBlock Text="Снимок сохраняется картинкой в выбранную папку." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwFile" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>

                        <Border Height="1" Background="#1EFFFFFF" Margin="0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Перехватывать Win + Print Screen" Style="{StaticResource H2}" />
                                <TextBlock Text="Обрабатывать и стандартную комбинацию Windows." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwWinPs" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>

                        <Border Height="1" Background="#1EFFFFFF" Margin="0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Звук затвора" Style="{StaticResource H2}" />
                                <TextBlock Text="Короткий сигнал при создании снимка." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwSound" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>

                        <Border Height="1" Background="#1EFFFFFF" Margin="0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Уведомления" Style="{StaticResource H2}" />
                                <TextBlock Text="Всплывающее уведомление после снимка." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwNotify" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>

                        <Border Height="1" Background="#1EFFFFFF" Margin="0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Плавные анимации" Style="{StaticResource H2}" />
                                <TextBlock Text="Анимации нажатий, переключателей и смены вкладок." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                            </StackPanel>
                            <CheckBox x:Name="SwAnim" Grid.Column="1" Style="{StaticResource GlassSwitch}" VerticalAlignment="Center" Click="Toggle_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Папка -->
                <TextBlock Text="Папка сохранения" Style="{StaticResource H2}" Margin="2,20,0,8" />
                <Border Style="{StaticResource Card}" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FolderText" Grid.Column="0" Style="{StaticResource Body}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                        <Button x:Name="BtnFolder" Grid.Column="1" Style="{StaticResource GlassButton}"
                                Content="Изменить" Margin="12,0,0,0" Click="BtnFolder_Click" />
                    </Grid>
                </Border>

                <!-- Поведение окон -->
                <TextBlock Text="Поведение окон" Style="{StaticResource H2}" Margin="2,20,0,8" />
                <Border Style="{StaticResource Card}" views:BindHelper.Action="minimize_monitor" Cursor="Hand">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Win + D — сворачивать только один монитор" Style="{StaticResource H2}" />
                            <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0"
                                       Text="Сворачиваются окна только на мониторе под курсором, остальные экраны не трогаются." />
                            <TextBlock x:Name="WinDHotkey" Style="{StaticResource Caption}" Margin="0,5,0,0"
                                       Foreground="{DynamicResource TextMuted}"
                                       Text="Клик колёсиком по строке — назначить свою горячую клавишу." />
                        </StackPanel>
                        <CheckBox x:Name="SwWinD" Grid.Column="1" Style="{StaticResource GlassSwitch}"
                                  VerticalAlignment="Center" Click="WinD_Click" />
                    </Grid>
                </Border>

                <Border Height="14" Background="Transparent" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
