<Window x:Class="TwoTo1Screen.Views.KeyBindWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Горячая клавиша"
        Width="380" Height="250"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Border CornerRadius="18" Background="{DynamicResource WindowFill}"
            BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1">
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Назначить горячую клавишу" Style="{StaticResource H2}" FontSize="16" />
                <TextBlock x:Name="ActionLabel" Style="{StaticResource Caption}" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="12" Background="{DynamicResource GlassFill}"
                    BorderBrush="{DynamicResource GlassStroke}" BorderThickness="1" Margin="0,16"
                    VerticalAlignment="Center">
                <TextBlock x:Name="ComboText" Text="Нажмите сочетание клавиш…"
                           Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,22" />
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Очистить" Style="{StaticResource GlassButton}" MinWidth="84" Click="Clear_Click" />
                <Button Content="Отмена" Style="{StaticResource GlassButton}" MinWidth="84" Margin="8,0,0,0" Click="Cancel_Click" />
                <Button x:Name="BtnSave" Content="Сохранить" Style="{StaticResource AccentButton}" MinWidth="100"
                        Padding="18,9" FontSize="13" Margin="8,0,0,0" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
