<Window x:Class="TwoTo1Screen.Views.ThemePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр темы"
        WindowStyle="None" ResizeMode="NoResize"
        WindowState="Maximized"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True"
        Background="#FF0E1014">

    <Grid x:Name="Root" Background="{DynamicResource WindowBackdrop}">
        <Grid x:Name="BackdropHost" />

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Grid Grid.Row="0" Height="58" Margin="18,8,18,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="9"
                            Background="{DynamicResource AccentGradient}" BorderBrush="#66FFFFFF" BorderThickness="1">
                        <TextBlock Text="2›1" Foreground="{DynamicResource AccentTextBrush}" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="2to1screen" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" />
                    <Border Background="#22FFFFFF" CornerRadius="8" Padding="10,3" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="PreviewBadge" Style="{StaticResource Caption}" Text="Предпросмотр темы" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Esc — закрыть" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Button Content="✕ Закрыть" Style="{StaticResource GhostButton}" Padding="14,8" FontSize="13"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="18,12,18,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" CornerRadius="16" Margin="0,0,12,0"
                        Background="{DynamicResource SidebarFill}"
                        BorderBrush="{DynamicResource GlassStrokeSoft}" BorderThickness="1">
                    <StackPanel Margin="0,10,0,0">
                        <RadioButton Style="{StaticResource NavItem}" GroupName="P" Tag="🖥️" Content="Приложение" IsChecked="True" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="P" Tag="⚙️" Content="Настройки" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="P" Tag="🎨" Content="Магазин тем" />
                        <RadioButton Style="{StaticResource NavItem}" GroupName="P" Tag="👤" Content="Разработчик" />
                    </StackPanel>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="2,0,2,14">
                        <TextBlock x:Name="ThemeTitle" Text="Тема" Style="{StaticResource H1}" />
                        <TextBlock x:Name="ThemeTagline" Style="{StaticResource Body}" Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Как это работает" Style="{StaticResource H2}" />
                                <TextBlock Style="{StaticResource Body}" Margin="0,10,0,0"
                                           Text="Нажмите «Запустить» — приложение перехватит Print Screen и сделает снимок только выбранного монитора в полном качестве." />
                                <WrapPanel Margin="0,14,0,0">
                                    <RadioButton Style="{StaticResource SelectChip}" GroupName="Q" Content="Очень высокое" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SelectChip}" GroupName="Q" Content="Высокое" />
                                    <RadioButton Style="{StaticResource SelectChip}" GroupName="Q" Content="Среднее" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Запускать автоматически" Style="{StaticResource H2}" />
                                    <TextBlock Text="Старт в фоне при входе в Windows." Style="{StaticResource Caption}" Margin="0,3,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource GlassSwitch}" IsChecked="True" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="2,16,2,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#FF5CCB8E" VerticalAlignment="Center" />
                            <TextBlock Text="Сервис работает — Print Screen перехвачен" Style="{StaticResource Body}"
                                       Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource AccentButton}" Content="Запустить" MinWidth="170" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
